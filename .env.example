# Copy to .env.local for local dev. Set these in Vercel project settings for production.
#
# Hosted Supabase: Dashboard → Project Settings → API (Project URL + anon public key).
# Local Supabase: run `npm run supabase:start`, then `npm run supabase:status` for URLs and keys.
#
# -----------------------------------------------------------------------------
# Supabase CLI (link + migrations)
# -----------------------------------------------------------------------------
# Newer CLIs link your folder to the hosted project using a Personal Access
# Token, not the database password. Database password is optional.
#
# 1) Create a token: https://supabase.com/dashboard/account/tokens
# 2) npm run db:login   (paste the token when asked)
# 3) npm run db:link -- --project-ref YOUR_PROJECT_REF
#    (ref is the short id in your project URL: app.supabase.com/project/<ref>)
#
# If the CLI does ask for a DB password but the prompt does not accept input
# (common in some Windows/npm setups), set it for that command only, then link:
#   PowerShell:
#     $env:SUPABASE_DB_PASSWORD = "your-database-password"
#     npx supabase link --project-ref YOUR_PROJECT_REF
#   Or run `npx supabase link ...` directly in a terminal (not via npm script).
#
# Database password: Dashboard → Project Settings → Database (reset if unsure).
# If linking fails through the pooler, try: --skip-pooler
#   npx supabase link --project-ref YOUR_REF --skip-pooler
#
# -----------------------------------------------------------------------------
# Auth (Dashboard → Authentication):
#   Turn ON "Anonymous sign-ins" (Providers / Sign In). The app uses anonymous
#   sessions—no email magic links—so RLS still has auth.uid().
#   Optional later: email OAuth + /auth/callback redirect URLs if you add login back.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: USDA FoodData Central API key for “Estimate calories” on recipes.
# Sign up (free): https://fdc.nal.usda.gov/api-key-signup.html
# USDA_FDC_API_KEY=your-fdc-key

# Optional: only for server-side admin operations if you add them later
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
